---
permalink: /bops/
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Songs by Bop Rating</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cormorant+Infant:wght@400;600&display=swap" />
    <link rel="stylesheet" href="{{ '/assets/style.css' | relativeUrl(page.url) }}" />
    <style>
      @page {
        size: A5;
        margin: 12mm 14mm;
        @bottom-right {
          content: counter(page) "/" counter(pages);
          font-family: "Cormorant", Georgia, serif;
          font-size: 9pt;
          color: #666;
        }
      }

      .bops-title {
        font-family: "Cormorant Infant", "Cormorant", Georgia, serif;
        font-size: 1.6rem;
        margin: 0 0 0.75rem;
        color: var(--fg);
      }

      .bops-section {
        margin-bottom: 0.9rem;
      }

      .bops-section h2 {
        break-after: avoid-column;
        font-family: "Cormorant Infant", "Cormorant", Georgia, serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--fg);
        margin: 0 0 0.15rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.1rem;
      }

      .bops-section ul {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .bops-section li {
        font-size: 0.8rem;
        line-height: 1.4;
        color: var(--fg);
        padding: 0;
      }

      .bops-columns {
        columns: 2;
        column-gap: 6mm;
      }

      .bops-cont-label {
        break-before: column;
        font-style: italic;
        font-weight: bold;
        font-size: 0.7rem;
        color: var(--muted);
        margin-bottom: 0.15rem;
        padding-bottom: 0.2rem;
        border-bottom: 1px solid currentColor;
      }

      @media print {
        .layout-toggle { display: none; }
        .bops-title { font-size: 1.3rem; margin-bottom: 0.5rem; }
        .bops-section h2 { font-size: 0.9rem; }
        .bops-section li { font-size: 0.75rem; }
        .bops-cont-label { font-size: 0.65rem; color: #999; }
      }
    </style>
  </head>
  <body class="print-layout">
    <p class="layout-toggle"><a href="{{ '/' | relativeUrl(page.url) }}">← Web view</a></p>
    <main>
      <h1 class="bops-title">Songs by Bop Rating</h1>
      <div class="bops-columns">
        {% for rating in [5, 4, 3, 2, 1] %}
          {% for entry in collections.indexEntries %}
            {% if entry.field == "bop_rating" and entry.value == rating %}
        <section class="bops-section">
          <h2>Bop {{ entry.value }}/5</h2>
          <ul>
            {% for song in entry.songs %}
            <li>{{ song.data.title }}</li>
            {% endfor %}
          </ul>
        </section>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
    </main>
  <script>
    function clearLabels() {
      document.querySelectorAll('.bops-cont-label').forEach(el => el.remove());
    }

    function insertLabels() {
      clearLabels();
      for (const section of document.querySelectorAll('.bops-section')) {
        const h2 = section.querySelector('h2');
        const ul = section.querySelector('ul');
        if (!h2 || !ul) continue;
        const heading = h2.textContent.trim();
        const lis = [...ul.querySelectorAll('li')];
        if (lis.length < 2) continue;

        const breakIndices = [];
        let prev = lis[0].getBoundingClientRect();
        for (let i = 1; i < lis.length; i++) {
          const r = lis[i].getBoundingClientRect();
          // Same-page left→right break: top resets upward.
          // Cross-page col2→col3 break: left jumps rightward by ~column width.
          if (r.top < prev.top - 2 || r.left > prev.left + 80) breakIndices.push(i);
          prev = r;
        }

        for (let b = breakIndices.length - 1; b >= 0; b--) {
          const label = document.createElement('li');
          label.className = 'bops-cont-label';
          label.textContent = `${heading} (cont.)`;
          ul.insertBefore(label, lis[breakIndices[b]]);
        }
      }
    }

    // Screen layout: insert labels after fonts settle.
    (document.fonts ? document.fonts.ready : Promise.resolve()).then(insertLabels);

    // Print layout: beforeprint fires before the browser applies @media print,
    // so we temporarily constrain the container to A5 dimensions with a fixed
    // height and column-fill:auto. This makes CSS columns overflow into col3,
    // col4… (laid out horizontally) rather than vertically — exactly mirroring
    // print pagination. We can then detect both same-page breaks (top resets)
    // and cross-page breaks (left jumps by ~column width). After measurement,
    // restore the original styles; the inserted break-before:column labels
    // handle the actual print layout.
    window.addEventListener('beforeprint', () => {
      const cols = document.querySelector('.bops-columns');
      if (!cols) return;
      const saved = cols.getAttribute('style') || '';
      cols.style.cssText = (saved ? saved + ';' : '') +
        'width:120mm;height:186mm;column-fill:auto;overflow:visible';
      void cols.offsetHeight; // force reflow before measuring
      insertLabels();
      cols.setAttribute('style', saved);
    });

    window.addEventListener('afterprint', insertLabels); // restore screen labels
  </script>
  </body>
</html>
