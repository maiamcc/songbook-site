---
pagination:
  data: collections.indexEntries
  size: 1
  alias: entry
permalink: "/index/{{ entry.field }}/{{ entry.slug }}/"
eleventyComputed:
  title: "{{ entry.field | replace('_', ' ') }}: {{ entry.value }}"
layout: base.njk
---
{% import "macros.njk" as m with context %}
<h1 class="index-heading">
  <span class="index-field">{{ entry.field | replace("_", " ") }}:</span>
  {% if entry.field == "bop_rating" -%}
    <span class="rating">{{ entry.value }} / 5</span>
  {%- else -%}
    {{ entry.value }}
  {%- endif %}
</h1>
<p class="index-count">{{ entry.songs.length }} song{% if entry.songs.length != 1 %}s{% endif %}</p>

<ul class="song-list">
  {% for song in entry.songs %}
    <li>
      <a href="{{ song.url | relativeUrl(page.url) }}">
        {{ song.data.title }}{% if song.data.alternate_title %}<span class="alt-title"> ({{ song.data.alternate_title }})</span>{% endif %}
      </a>
      <div class="index-meta">
        {% if song.data.genre %}<span>{{ m.indexLink("genre", song.data.genre, song.data.genre) }}</span>{% endif %}
        {% if song.data.mood %}<span>{{ m.indexLink("mood", song.data.mood, song.data.mood) }}</span>{% endif %}
        {% if song.data.bop_rating %}
          <span class="rating">{{ m.indexLink("bop_rating", song.data.bop_rating, song.data.bop_rating ~ " / 5") }}</span>
        {% endif %}
        {% if song.data.structure %}<span>{{ m.indexLink("structure", song.data.structure, song.data.structure) }}</span>{% endif %}
        {% if song.data.topics %}<span>{% for t in song.data.topics %}{{ m.indexLink("topics", t, t) }}{% if not loop.last %}, {% endif %}{% endfor %}</span>{% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
