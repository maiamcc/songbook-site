---
layout: base.njk
---
<article class="song">
  <h1>{{ title }}</h1>
  {% if alternate_title %}<p class="alt-title">{{ alternate_title }}</p>{% endif %}
  {% if author or year_written %}
  <p class="byline">
    {%- if author %}{{ author }}{% endif -%}
    {%- if author and year_written %} · {% endif -%}
    {%- if year_written %}{{ year_written }}{% endif -%}
  </p>
  {% endif %}

  {% if genre or mood or bop_rating or structure or topics %}
  <dl class="song-meta">
    {% if genre %}<dt>Genre</dt><dd>{{ genre }}</dd>{% endif %}
    {% if mood %}<dt>Mood</dt><dd>{{ mood }}</dd>{% endif %}
    {% if bop_rating %}<dt>Bop rating</dt><dd class="rating">{% for i in range(bop_rating) %}★{% endfor %}{% for i in range(5 - bop_rating) %}☆{% endfor %}</dd>{% endif %}
    {% if structure %}<dt>Structure</dt><dd>{{ structure }}</dd>{% endif %}
    {% if topics %}<dt>Topics</dt><dd>{{ topics | join(", ") }}</dd>{% endif %}
  </dl>
  {% endif %}

  {% if notes %}<p class="notes"><strong>Notes:</strong> {{ notes }}</p>{% endif %}

  <div class="song-body">
    {{ content | safe }}
  </div>
</article>
