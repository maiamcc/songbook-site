---
layout: base.njk
---
{% import "macros.njk" as m with context %}
<article class="song">
  <header class="song-header">
    <h1>
      {{ title }}{% if alternate_title %} <span class="alt-title">({{ alternate_title }})</span>{% endif %}
    </h1>
    {% if author or year_written %}
    <p class="byline">
      {%- if author %}{{ author }}{% endif -%}
      {%- if author and year_written %} · {% endif -%}
      {%- if year_written %}{{ year_written }}{% endif -%}
    </p>
    {% endif %}

    {% if genre or mood or bop_rating or structure or topics %}
    <dl class="song-meta">
      {% if genre %}<dt data-field="genre">Genre</dt><dd data-field="genre">{{ m.indexLink("genre", genre, genre) }}</dd>{% endif %}
      {% if mood %}<dt data-field="mood">Mood</dt><dd data-field="mood">{{ m.indexLink("mood", mood, mood) }}</dd>{% endif %}
      {% if bop_rating %}
        <dt class="screen-only" data-field="bop_rating">Bop rating</dt><dd class="rating" data-field="bop_rating"><span class="screen-only">{{ m.indexLink("bop_rating", bop_rating, bop_rating ~ " / 5") }}</span><span class="print-only">Bop:&nbsp;{{ bop_rating }}</span></dd>
      {% endif %}
      {% if structure %}<dt data-field="structure">Structure</dt><dd data-field="structure">{{ m.indexLink("structure", structure, structure) }}</dd>{% endif %}
      {% if topics %}<dt data-field="topics">Topics</dt><dd data-field="topics">{% for t in topics %}{{ m.indexLink("topics", t, t) }}{% if not loop.last %}, {% endif %}{% endfor %}</dd>{% endif %}
    </dl>
    {% endif %}

  </header>

  <div class="song-body">
    {{ content | safe }}
  </div>

  {% if notes %}<p class="notes"><span class="notes-label">Notes:</span> {{ notes }}</p>{% endif %}
</article>
