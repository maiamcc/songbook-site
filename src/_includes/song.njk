---
layout: base.njk
---
{% import "macros.njk" as m with context %}
<article class="song">
  <header class="song-header">
    <h1>
      {{ title }}{% if alternate_title %} <span class="alt-title">({{ alternate_title }})</span>{% endif %}
    </h1>
    {% if author or year_written %}
    <p class="byline">
      {%- if author %}{{ author }}{% endif -%}
      {%- if author and year_written %} · {% endif -%}
      {%- if year_written %}{{ year_written }}{% endif -%}
    </p>
    {% endif %}

    {% if genre or mood or bop_rating or structure or topics %}
    <dl class="song-meta">
      {% if genre %}<dt>Genre</dt><dd>{{ m.indexLink("genre", genre, genre) }}</dd>{% endif %}
      {% if mood %}<dt>Mood</dt><dd>{{ m.indexLink("mood", mood, mood) }}</dd>{% endif %}
      {% if bop_rating %}
        {%- set stars %}{% for i in range(bop_rating) %}★{% endfor %}{% for i in range(5 - bop_rating) %}☆{% endfor %}{% endset -%}
        <dt>Bop rating</dt><dd class="rating">{{ m.indexLink("bop_rating", bop_rating, stars) }}</dd>
      {% endif %}
      {% if structure %}<dt>Structure</dt><dd>{{ m.indexLink("structure", structure, structure) }}</dd>{% endif %}
      {% if topics %}<dt>Topics</dt><dd>{% for t in topics %}{{ m.indexLink("topics", t, t) }}{% if not loop.last %}, {% endif %}{% endfor %}</dd>{% endif %}
    </dl>
    {% endif %}

  </header>

  <div class="song-body">
    {{ content | safe }}
  </div>

  {% if notes %}<p class="notes"><span class="notes-label">Notes:</span> {{ notes }}</p>{% endif %}
</article>
