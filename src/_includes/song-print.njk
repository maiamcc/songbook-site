{# Macro that renders the print-mode markup for a single song. `s` is
   the song's data object (per lib/song-schema.js — fields like title,
   author, bop_rating, notes); `bodyHtml` is the rendered HTML for the
   markdown body. Only fields whose schema entry includes "print" in
   `display` are rendered here, so the print layout doesn't need any
   CSS hiding to suppress non-printing fields. #}
{% macro renderSongPrint(s, bodyHtml) %}
<article class="song">
  <header class="song-header">
    {# Float-right vitals goes BEFORE the h1 in source so it lands at
       the top-right of the song-header (alongside the title), not
       beneath the byline. The h1's text wraps around it on the left. #}
    {% if s.bop_rating or s.rnge %}
    <div class="song-vitals">
      {% if s.bop_rating %}
      <dl class="song-meta">
        <dt>Bop</dt><dd>{{ s.bop_rating }}</dd>
      </dl>
      {% endif %}
      {% if s.rnge %}
      {% set rngeParts = s.rnge.split(">") %}
      <dl class="song-meta">
        <dt class="visually-hidden">Range</dt><dd><span class="range">{{ rngeParts[0] }}<svg class="range-arrow" viewBox="0 0 10 10" aria-hidden="true"><path d="M 1.5 5 H 8.5 M 6 3 L 8.5 5 L 6 7" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" stroke-linejoin="round" fill="none" /></svg>{{ rngeParts[1] }}</span></dd>
      </dl>
      {% endif %}
    </div>
    {% endif %}
    <h1>
      {{ s.title }}{% if s.alternate_title %} <span class="alt-title">({{ s.alternate_title }})</span>{% endif %}
    </h1>
    {% if s.author %}
    <p class="byline">{{ s.author }}</p>
    {% endif %}
  </header>

  <div class="song-body">
    {{ bodyHtml | safe }}
  </div>

  {% if s.notes %}
  <hr class="notes-sep" />
  <p class="notes"><span class="notes-label">Notes:</span> {{ s.notes | inlineMarkdown | safe }}</p>
  {% endif %}
</article>
{% endmacro %}
