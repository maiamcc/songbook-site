<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Choruses</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cormorant+Infant:wght@400;600&display=swap" />
    <link rel="stylesheet" href="{{ '/assets/style.css' | relativeUrl(page.url) }}" />
    <style>
      @page {
        size: letter;
        margin: 0.35in 0.55in 0.6in;
        @bottom-left {
          content: "Maia McCormick | maia.mcc@gmail.com";
          font-family: "Cormorant", Georgia, serif;
          font-size: 9pt;
          color: #666;
        }
        @bottom-right {
          content: counter(page) "/" counter(pages);
          font-family: "Cormorant", Georgia, serif;
          font-size: 9pt;
          color: #666;
        }
      }
    </style>
  </head>
  <body class="print-layout choruses-print">
    <main>
      {% set sections = content | parseChorusSections %}
      <h1 class="choruses-page-title">Assorted Choruses</h1>
      <p class="choruses-page-subtitle">Compiled by Maia McCormick for Lady of the Lake, June 2026</p>
      <ol class="choruses-toc">
        {% for s in sections %}<li>{{ s.shortTitle }}</li>
        {% endfor %}
      </ol>
      <div class="choruses-body">
        {% for s in sections %}
        <section class="chorus-entry">{{ s.html | safe }}</section>
        {% endfor %}
      </div>
    </main>
  </body>
</html>
