{# Shared template macros. Imported via {% import "macros.njk" as m %}. #}

{# Render an indexable (field, value) pair as a link to its index page,
   with a "N songs" tooltip. `inner` is the visible text — usually the
   value itself, but for bop_rating it's the rendered star block.
   Requires the `collections.indexEntries` and `indexCount`/`slugify`
   filters from eleventy.config.js. #}
{% macro indexLink(field, value, inner) -%}
  {%- set n = collections.indexEntries | indexCount(field, value) -%}
  {%- set href = "/index/" ~ field ~ "/" ~ (value | slugify) ~ "/" -%}
  <a href="{{ href | relativeUrl(page.url) }}" title="{{ n }} song{% if n != 1 %}s{% endif %}">{{ inner | safe }}</a>
{%- endmacro %}

{# Render an enum value as a link to its index page, with the value's
   description as the tooltip (pulled from the `enums` global, populated
   from lib/enums.yaml). Use this for closed-set fields defined via
   enumField() in song-schema.js where the per-value semantic is more
   informative than the song-count standard indexLink emits. #}
{% macro enumLink(field, value) -%}
  {%- set href = "/index/" ~ field ~ "/" ~ (value | slugify) ~ "/" -%}
  {%- set desc = enums[field].values[value] -%}
  <a href="{{ href | relativeUrl(page.url) }}" title="{{ desc }}">{{ value | humanize }}</a>
{%- endmacro %}

{# Render a "?" help affordance with a CSS-driven hover tooltip listing
   the field's description and every legal value + description (pulled
   from the `enums` global). Replaces the native title-attribute
   tooltip so the content can be styled — values render as a <dl>
   laid out as a grid so wrapped description lines hang-indent under
   the description column rather than wrapping flush-left under the
   value name. `label` is the screen-reader name for the trigger. #}
{% macro enumHelp(field, label) -%}
<span class="enum-help">
  <span class="enum-legend" tabindex="0" aria-label="{{ label }}">?</span>
  <span class="enum-tooltip" role="tooltip">
    {% if enums[field].desc %}<span class="enum-tooltip-desc">{{ enums[field].desc }}</span>{% endif %}
    <dl>{% for k, v in enums[field].values %}<dt>{{ k | humanize }}</dt><dd>{{ v }}</dd>{% endfor %}</dl>
  </span>
</span>
{%- endmacro %}
