{
  "name": "songbook-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "eleventy --serve",
    "build": "eleventy",
    "clean": "find _site -mindepth 1 -maxdepth 1 -not -name .git -exec rm -rf {} + 2>/dev/null || true",
    "test": "node --test test/*.test.js",
    "new-song": "node scripts/new-song.js",
    "import-songs": "node scripts/import-songs.js",
    "stash-songs": "node scripts/stash-songs.js",
    "unstash-songs": "node scripts/stash-songs.js --unstash",
    "dump-choruses": "node scripts/dump-choruses.js",
    "check-print-pages": "npm run build && node scripts/check-print-pages.js",
    "deploy": "npm run clean && npm run build && cd _site && git add -A && (git diff --cached --quiet && echo 'No changes to commit; pushing any prior unpushed commits.' || git commit -m \"Deploy $(date -u +%Y-%m-%dT%H:%M:%SZ)\") && git push",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.0",
    "nunjucks": "^3.2.4"
  }
}
